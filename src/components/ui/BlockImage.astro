---
import { type CameraAngle, renderBlockDataUrl } from '@utils/model-renderer';
import type { CollectionEntry } from 'astro:content';

interface Props {
  blockId: string;
  version: CollectionEntry<'versions'>;
  alt?: string;
  width?: number;
  height?: number;
  angle?: CameraAngle;
  rotation?: number;
  class?: string;
}

const { blockId, version, alt, width = 256, height = width, angle, rotation, class: className } = Astro.props;

const src = await renderBlockDataUrl(blockId, { version, width, height, angle, rotation });
---

<img src={src} alt={alt || blockId} width={width} height={height} class={className} loading="lazy" decoding="async" />
