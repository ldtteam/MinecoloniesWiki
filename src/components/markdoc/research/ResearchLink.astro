---
import { getSortedVersions, getVersionedEntry } from '../../../util/version';
import VersionContent from '../../version/VersionContent.astro';
import ResearchLinkInternal from './ResearchLinkInternal.astro';

interface Props {
  name: string;
}

const { name } = Astro.props;

const versions = await getSortedVersions();
---

{
  versions.map(async (version) => {
    const researchEffect = await getVersionedEntry('research_effect', version, name);
    if (researchEffect === undefined) {
      throw new Error(`Research effect with given id "${researchEffect}" does not exist.`);
    }
    return (
      <VersionContent versions={[version]}>
        <ResearchLinkInternal researchEffect={researchEffect} />
      </VersionContent>
    );
  })
}
