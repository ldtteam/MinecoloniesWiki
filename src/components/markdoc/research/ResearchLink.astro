---
import VersionContent from '@components/version/VersionContent.astro';
import { getSortedVersions } from '@utils/version';
import { getEntry } from 'astro:content';

import ResearchLinkInternal from './ResearchLinkInternal.astro';

interface Props {
  name: string;
}

const { name } = Astro.props;

const versions = await getSortedVersions();
---

{
  versions.map(async (version) => {
    const researchKey = `${version.data.order}_${name}`;
    const research = await getEntry('research', researchKey);
    if (research === undefined) {
      throw new Error(`Research with given id "${researchKey}" does not exist.`);
    }
    return (
      <VersionContent versions={[version]}>
        <ResearchLinkInternal research={research} />
      </VersionContent>
    );
  })
}
