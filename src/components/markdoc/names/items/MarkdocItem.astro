---
import { getItemLink } from '../../../../util/items';
import { getNewestVersion, getVersionedEntry } from '../../../../util/version';
import ItemNameAllVersions from '../../../wiki/names/items/ItemNameAllVersions.astro';

interface Props {
  currentPage: string;
  name: string;
}

const { currentPage, name } = Astro.props;

const latestVersion = await getNewestVersion();
const item = await getVersionedEntry('items', latestVersion, name);
if (item === undefined) {
  throw new Error(`Item ${name} does not exist for version ${latestVersion.id}.`);
}

const itemLink = await getItemLink(item);
---

<ItemNameAllVersions item={name} link={itemLink !== '/wiki/' + currentPage} inline />
