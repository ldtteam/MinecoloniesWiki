---
import type { CollectionEntry } from 'astro:content';

import Card from '../common/basic/Card.astro';
import MinecraftSkin from '../common/MinecraftSkin.astro';

interface Props {
  member: CollectionEntry<'team'>;
}

const { member } = Astro.props;
---

<Card class="member-card" autoSize>
  {member.data.uuid && <MinecraftSkin uuid={member.data.uuid} name={member.id} class="member-image" />}

  <div class="member-details">
    <h3 class="pt-3">{member.id}</h3>
    {member.data.joinedYear !== undefined && <p>Joined: {member.data.joinedYear}</p>}

    {
      member.data.sub !== undefined && (
        <p>
          {member.data.sub.map((sub) => (
            <>
              <span>{sub}</span>
              <br />
            </>
          ))}
        </p>
      )
    }
    <p><i>{member.data.tagline}</i></p>
  </div>
</Card>

<style>
  :global(.member-card) {
    display: flex;
    gap: 1em;
  }

  .member-image {
    flex: 0;
    height: min-content;
  }

  .member-details {
    flex: 1;
  }
</style>
