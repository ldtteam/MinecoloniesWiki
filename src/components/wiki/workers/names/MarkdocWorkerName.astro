---
import { getEntry } from 'astro:content';

import { getSortedVersions, getVersionedEntry } from '../../../../util/version';
import WorkerNameAllVersions from './WorkerNameAllVersions.astro';

interface Props {
  name?: string;
  building?: string;
  plural?: boolean;
  link?: boolean;
}

const { name, building, plural = false, link } = Astro.props;

const frontmatter = Astro.locals.wikiPage?.data;
const workerIdFromPage =
  frontmatter?.type === 'building' && frontmatter.workers?.length === 1 ? frontmatter.workers[0].id : undefined;
const workerBaseId = name ?? workerIdFromPage ?? '';

let buildingBaseId = building;
if (buildingBaseId === undefined) {
  const versions = await getSortedVersions();
  for (const version of versions) {
    const workerData = await getVersionedEntry('workers', version, workerBaseId);
    if (workerData !== undefined) {
      buildingBaseId = (await getEntry(workerData.data.primaryBuilding))?.data.baseId ?? workerBaseId;
      break;
    }
  }
  buildingBaseId ??= workerBaseId;
}
---

<WorkerNameAllVersions
  buildingBaseId={buildingBaseId}
  workerBaseId={workerBaseId}
  link={link !== false && workerIdFromPage !== workerBaseId}
  plural={plural}
/>
