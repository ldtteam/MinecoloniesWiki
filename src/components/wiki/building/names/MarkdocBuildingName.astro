---
import BuildingNameAllVersions from './BuildingNameAllVersions.astro';

interface Props {
  name?: string;
  plural?: boolean;
}

const { name, plural = false } = Astro.props;

const currentBuilding = Astro.locals.wikiPage?.data?.type === 'building' ? Astro.locals.wikiPage?.data.id : undefined;
const buildingBaseId = name ?? currentBuilding ?? '';
---

<BuildingNameAllVersions buildingBaseId={buildingBaseId} link={currentBuilding !== buildingBaseId} plural={plural} />
