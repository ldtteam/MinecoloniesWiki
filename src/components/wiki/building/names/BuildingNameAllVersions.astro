---
import type { CollectionEntry } from 'astro:content';

import { getSortedVersions } from '../../../../util/version';
import VersionContent from '../../../common/version/VersionContent.astro';
import BuildingName from './BuildingName.astro';

interface Props {
  building: CollectionEntry<'buildings'>;
  link?: boolean;
  plural?: boolean;
}

const { building, link = false, plural = false } = Astro.props;

const versions = await getSortedVersions();
---

{
  versions.map((version) => (
    <VersionContent versions={[version]}>
      <BuildingName version={version} building={building} link={link} plural={plural} />
    </VersionContent>
  ))
}
