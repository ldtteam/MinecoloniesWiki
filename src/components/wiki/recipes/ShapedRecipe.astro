---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';

import type { RecipeSchema } from '../../../schemas/item';
import { resolveSlots } from '../../../util/recipe';
import VersionSlideshow from '../../common/version/VersionSlideshow.astro';
import RecipeSlot from './RecipeSlot.astro';

interface Props {
  recipe: Extract<RecipeSchema, { type: 'shaped' }>;
  version: CollectionEntry<'versions'>;
}

const { recipe, version } = Astro.props;

const inputSlots = [
  recipe.items.at(0)?.at(0),
  recipe.items.at(0)?.at(1),
  recipe.items.at(0)?.at(2),
  recipe.items.at(1)?.at(0),
  recipe.items.at(1)?.at(1),
  recipe.items.at(1)?.at(2),
  recipe.items.at(2)?.at(0),
  recipe.items.at(2)?.at(1),
  recipe.items.at(2)?.at(2)
];

const output = await getEntry(recipe.output);
const { frames } = await resolveSlots(inputSlots);

const group = `shaped-${Math.random().toString(36).slice(2)}`;
const slotColumns = inputSlots.map((_, i) => frames.map((frame) => frame[i]));
---

<VersionSlideshow version={version} group={group}>
  <div class="recipe-frame">
    <div class="inputs">
      {slotColumns.map((items) => <RecipeSlot items={items} />)}
    </div>
    <div class="output">
      <RecipeSlot items={[output]} amount={recipe.amount} large />
    </div>
  </div>
</VersionSlideshow>

<style>
  .recipe-frame {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1em;
  }

  .inputs {
    display: grid;
    grid-template-columns: repeat(3, 2em);
    grid-template-rows: repeat(3, 2em);
  }

  .output {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
</style>
