---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import Infobox from '../../../core/infobox/Infobox.astro';
import RecipeGrid from '../../../core/infobox/RecipeGrid.astro';
import ItemImage from '../../items/ItemImage.astro';
import ItemName from '../../names/items/ItemName.astro';

interface Props {
  item: CollectionEntry<'items'>;
  expand?: boolean;
}

const { item, expand = false } = Astro.props;

const recipes = await getCollection('recipes', (recipe) => recipe.data.output.id === item.id);
---

<Infobox class:list={['w-auto', 'flex-shrink-1', expand ? 'h-100' : '']} expand={expand}>
  <ItemName slot="title" item={item} link={false} />

  <div class="text-center">
    <ItemImage item={item} alt={item.data.name + ' icon'} size={150} />
  </div>

  <RecipeGrid recipes={recipes} />
</Infobox>

<style>
  .recipe-grid {
    display: grid;
    grid-template-columns: auto max-content;
    gap: 0.5em;
  }
</style>
