---
import MarkdocBuildingName from '../../building/names/MarkdocBuildingName.astro';
import BuildingContentBlock from '../BuildingContentBlock.astro';
import type { BaseBuildingContentBlockProps } from '../types';

type Props = BaseBuildingContentBlockProps;
---

<BuildingContentBlock {...Astro.props} header="minimum stock" imageKey="stock" imageAlt="Minimum stock">
  <p>
    Use this button to tell the <MarkdocBuildingName {...Astro.props} /> to keep a minimum stock on hand. Set items will be
    displayed above the button.
  </p>
</BuildingContentBlock>
