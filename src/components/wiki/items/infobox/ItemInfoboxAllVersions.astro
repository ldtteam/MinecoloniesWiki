---
import { getSortedVersions, getVersionedEntry } from '../../../../util/version';
import VersionContent from '../../../common/version/VersionContent.astro';
import ItemInfobox from './ItemInfobox.astro';

interface Props {
  id: string;
  expand?: boolean;
}

const { id } = Astro.props;

const versions = await getSortedVersions();
const entries = (
  await Promise.all(
    versions.map(async (version) => {
      const item = await getVersionedEntry('items', version, id);
      return item ? { version, item } : undefined;
    })
  )
).filter((e) => e !== undefined);

if (entries.length === 0) {
  throw new Error(`Item ${id} does not exist in any version.`);
}
---

{
  entries.map(({ version, item }) => (
    <VersionContent versions={[version]}>
      <ItemInfobox item={item} />
    </VersionContent>
  ))
}
