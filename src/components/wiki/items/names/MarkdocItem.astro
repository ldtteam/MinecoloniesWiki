---
import { getItemLinkByBaseId } from '../../../../util/items';
import ItemNameAllVersions from './ItemNameAllVersions.astro';

interface Props {
  name: string;
}

const { name } = Astro.props;

const itemLink = await getItemLinkByBaseId(name);
---

<ItemNameAllVersions item={name} link={itemLink !== '/wiki/' + Astro.locals.wikiPage?.id} inline />
