---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'items'>;
  alt?: string;
  size: number;
  class?: string;
}

const { item, alt, size, class: className } = Astro.props;

const version = await getEntry(item.data.version);
const [namespace, ...itemPath] = item.data.baseId.split('/');

const src = `/images/wiki/items/${version.data.submodule}/${namespace}/${itemPath.join('/')}.png`;
---

{
  src && (
    <img
      src={src}
      alt={alt || item.data.name}
      loading="lazy"
      decoding="async"
      width={size}
      height={size}
      class={className}
    />
  )
}
