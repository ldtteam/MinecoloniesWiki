---
import { type CameraAngle, renderItemOrBlockDataUrl } from '@utils/renderers';
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'items'>;
  alt?: string;
  size: number;
  angle?: CameraAngle;
  rotation?: number;
  class?: string;
}

const { item, alt, size, angle, rotation, class: className } = Astro.props;

const src = await renderItemOrBlockDataUrl(item, {
  width: size,
  height: size,
  angle,
  rotation
});
---

{
  src && (
    <img
      src={src}
      alt={alt || item.data.name}
      loading="lazy"
      decoding="async"
      width={size}
      height={size}
      class={className}
    />
  )
}
