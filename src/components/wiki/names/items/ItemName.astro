---
import type { CollectionEntry } from 'astro:content';

import { getItemLink } from '../../../../util/items';

interface Props {
  item: CollectionEntry<'items'>;
  link?: boolean;
}

const { item, link = true } = Astro.props;
---

{link ? <a href={await getItemLink(item)}>{item.data.name}</a> : item.data.name}
