---
import Card from '../basic/Card.astro';

interface Props {
  expand?: boolean;
  class?: string;
  fullWidth?: boolean;
}

const { expand = false, class: cssClass, fullWidth = false } = Astro.props;
---

<div class={cssClass}>
  <Card padding={2} class={expand ? 'h-100' : ''} autoSize={fullWidth}>
    {
      Astro.slots.has('title') && (
        <h2 class="text-center">
          <slot name="title" />
        </h2>
      )
    }

    <hr />

    <slot />
  </Card>
</div>
