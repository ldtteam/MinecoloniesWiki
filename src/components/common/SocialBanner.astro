---
import { getEntry } from 'astro:content';

import Social from '../wiki/util/MarkdocSocialLink.astro';
import Banner, { type Props as BannerProps } from './basic/Banner.astro';

interface Props extends Omit<BannerProps, 'image'> {
  id: string;
}

const { id, ...rest } = Astro.props;
const textColor = rest.textColor ?? 'white';

const social = await getEntry('socials', id);
if (social === undefined) {
  throw new Error(`Social with '${social}' does not exist.`);
}
---

<Banner {...rest} offset={20} image={`/images/banner/${social.id}.png`} class="social-banner">
  <Social id={id} icon color={textColor} />

  <span style={{ color: textColor }}>
    <slot />
  </span>
</Banner>

<style>
  a {
    padding-left: 1em;
    padding-right: 1em;
  }

  .social-banner {
    gap: 1em;
  }
</style>
