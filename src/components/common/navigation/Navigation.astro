---
import { Icon } from 'astro-icon/components';

import Ribbon from '../basic/Ribbon.astro';
import Header from '../core/Header.astro';
import VersionSelector from '../version/VersionSelector.astro';
import MainPages from './MainPages.astro';
import Socials from './Socials.astro';
import ThemeSwitcher from './ThemeSwitcher.astro';
import WikiPages from './WikiPages.astro';

interface Props {
  isWiki: boolean;
  showVersionSelector: boolean;
}

const { isWiki, showVersionSelector } = Astro.props;

const expand = 'lg';
---

<Ribbon class={`navbar navbar-expand-${expand} navbar-light`} as="nav">
  <div class="mx-5 w-100">
    <div class="container d-flex justify-content-between align-items-center">
      <button
        class={`d-${expand}-none btn btn-outline-light`}
        type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#mobileMenu"
      >
        <Icon name="material-symbols-light:menu-rounded" />
      </button>

      <div class="navbar-collapse collapse justify-content-between">
        <ul class="navbar-nav">
          <MainPages />
        </ul>
        <ul class="navbar-nav flex-row align-items-center">
          <li class="nav-item d-none d-lg-block">
            <a
              class="nav-link report-bug-link"
              href="https://github.com/ldtteam/minecolonies/issues/new/choose"
              target="_blank"
              rel="noopener noreferrer"
            >
              Report a Bug <Icon name="material-symbols-light:open-in-new" size={14} />
            </a>
          </li>
          <Socials />
        </ul>
      </div>

      <ul class="navbar-nav">
        <li class="nav-item">
          <ThemeSwitcher />
        </li>
      </ul>

      <div class={`offcanvas offcanvas-start d-${expand}-none`} id="mobileMenu">
        <div class="offcanvas-header d-flex justify-content-between align-items-start">
          <h5 class="offcanvas-title w-75" id="mobileMenuLabel">
            <Header isWiki={false} />
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
          <div class="flex-grow-1 overflow-scroll gap-1">
            <ul class="navbar-nav">
              <MainPages />
            </ul>

            {
              isWiki && (
                <>
                  <hr />

                  <WikiPages />
                </>
              )
            }

            {showVersionSelector && <hr />}
            {showVersionSelector && <VersionSelector />}
            <hr />

            <ul class="nav">
              <Socials />
            </ul>
            <hr />
            <a
              class="report-bug-link"
              href="https://github.com/ldtteam/minecolonies/issues/new/choose"
              target="_blank"
              rel="noopener noreferrer"
            >
              Report a Bug <Icon name="material-symbols-light:open-in-new" size={14} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Ribbon>

<style>
  .report-bug-link {
    font-size: 0.85em;
    white-space: nowrap;
    color: inherit;
  }
</style>

{
  isWiki && (
    <Ribbon class={`navbar navbar-expand-${expand} navbar-light d-none d-${expand}-flex`} as="nav">
      <div class="container">
        <div class="navbar-collapse collapse">
          <WikiPages isAppbar />
        </div>
      </div>
    </Ribbon>
  )
}
