---
import type { Title } from '../../../util/wiki';
import VersionContent from '../version/VersionContent.astro';

interface Props {
  title: Title;
}

const { title } = Astro.props;
---

{
  typeof title === 'string'
    ? title
    : title.values.map((titleVersion) => (
        <VersionContent versions={titleVersion.versions}>{titleVersion.value}</VersionContent>
      ))
}
