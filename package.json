{
  "name": "minecolonies-wiki",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm run update:submodule && pnpm run lint && astro build",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "lint": "astro check && tsc --noEmit && pnpm run eslint",
    "lint:fix": "astro check && tsc --noEmit && pnpm run eslint:fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "preview": "astro preview",
    "start": "pnpm run update:submodule && astro dev",
    "sync": "astro sync",
    "upgrade": "pnpm run upgrade:astro && pnpm run upgrade:deps",
    "upgrade:astro": "pnpm dlx @astrojs/upgrade",
    "upgrade:deps": "ncu -u -x sass,three,gl,vite && pnpm install",
    "update:submodule": "git submodule update --init --remote --recursive --merge"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/markdoc": "^0.15.10",
    "@astrojs/markdown-remark": "^6.3.10",
    "@astrojs/node": "^9.5.1",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/svelte": "^7.2.4",
    "@iconify-json/cib": "^1.2.3",
    "@iconify-json/material-symbols-light": "^1.2.50",
    "@iconify/json": "^2.2.425",
    "@markdoc/markdoc": "^0.5.4",
    "@types/three": "^0.182.0",
    "archiver": "^7.0.1",
    "astro": "^5.16.6",
    "astro-icon": "1.1.5",
    "bootstrap": "^5.3.8",
    "canvas": "^3.2.0",
    "date-fns": "^4.1.0",
    "gl": "^8.1.6",
    "iconify": "^1.4.0",
    "mdast-util-directive": "^3.1.0",
    "minecraft-assets": "1.17.0",
    "minecraft-data": "^3.102.3",
    "p-limit": "^7.2.0",
    "remark-directive": "^4.0.0",
    "sharp": "^0.34.5",
    "svelte": "^5.46.1",
    "swiper": "^12.0.3",
    "three": "^0.124.0",
    "unist-util-visit": "^5.0.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@astrojs/upgrade": "^0.6.2",
    "@eslint/js": "^9.39.2",
    "@types/archiver": "^7.0.0",
    "@types/bootstrap": "^5.2.10",
    "@types/eslint-plugin-markdown": "^2.0.2",
    "astro-eslint-parser": "^1.2.2",
    "astro-purgecss": "^5.3.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "npm-check-updates": "^19.3.1",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "purgecss": "^7.0.2",
    "sass": "^1.77.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.52.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "sharp"
    ]
  }
}
